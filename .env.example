# Cloudflare AI Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# AI Model Configuration
# Available models:
# - @cf/meta/llama-3.3-70b-instruct-fp8-fast (recommended - faster, smarter)
# - @cf/meta/llama-3.1-8b-instruct (original - smaller, faster)
# - @cf/meta/llama-3.2-11b-vision-instruct (with vision capabilities)
CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Optional: Set default network (mainnet or testnet)
DEFAULT_NETWORK=mainnet